{
  "name": "lms-backend",
  "version": "1.0.0",
  "description": "LMS Backend API",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "test:rules": "ts-node --transpile-only src/services/accessRuleSets.test.ts",
    "test:schedule": "ts-node --transpile-only src/services/notificationSchedule.test.ts",
