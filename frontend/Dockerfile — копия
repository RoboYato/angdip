FROM node:18-alpine as build

# Invalidate cache
ARG CACHEBUST=2
RUN echo "Cache bust: $CACHEBUST"

WORKDIR /app

COPY package*.json ./

RUN npm install

COPY . .

# Clear Angular cache before build
RUN rm -rf .angular/cache

RUN npm run build

FROM node:18-alpine

# Invalidate cache for final stage too
ARG CACHEBUST=2
RUN echo "Cache bust final: $CACHEBUST"

WORKDIR /app

RUN npm install -g http-server

COPY --from=build /app/dist/lms-frontend ./dist

EXPOSE 8080

CMD ["http-server", "dist", "-p", "8080", "-a", "0.0.0.0", "--cors"]
